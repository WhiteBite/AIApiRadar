# Copy to .env and fill in. Never commit .env.

# --- Storage ---
# SQLite for local dev; swap for postgresql+psycopg://user:pass@host/db later.
AIRADAR_DB_URL=sqlite:///./aiapiradar.db

# --- Logging ---
AIRADAR_LOG_LEVEL=INFO

# --- LLM classifier ---
# provider is informational; client is OpenAI-compatible.
AIRADAR_LLM_PROVIDER=openai
AIRADAR_LLM_BASE_URL=https://api.openai.com/v1
AIRADAR_LLM_MODEL=gpt-4o-mini
AIRADAR_LLM_API_KEY=

# --- Collector API keys (optional) ---
AIRADAR_GITHUB_TOKEN=
AIRADAR_SEARCH_API_KEY=
AIRADAR_SEARCH_CX=
AIRADAR_YOUTUBE_API_KEY=

# --- Telegram ingest (Telethon user client; optional) ---
# Get api_id/api_hash from https://my.telegram.org . First run is interactive
# (creates the .session file). Source counts as 'aggregator' for lead metrics.
AIRADAR_TG_API_ID=
AIRADAR_TG_API_HASH=
AIRADAR_TG_SESSION=aiapiradar

# --- FOFA (optional; favicon-hash relay discovery) ---
# Get credentials at https://fofa.info . Free tier quotas are tiny.
AIRADAR_FOFA_KEY=
AIRADAR_FOFA_EMAIL=

# --- Scoring weights (optional overrides) ---
AIRADAR_SCORE_W_FRESHNESS=0.4
AIRADAR_SCORE_W_AMOUNT=0.3
AIRADAR_SCORE_W_EASE=0.2
AIRADAR_SCORE_W_RELIABILITY=0.1

# --- Notifier (Phase 5) ---
AIRADAR_TG_BOT_TOKEN=
AIRADAR_TG_CHAT_ID=
AIRADAR_NOTIFY_MIN_SCORE=0.6

# --- RSSHub instance (for Chinese social platform feeds) ---
# Point at a self-hosted instance to avoid rate-limits on the public one.
# https://github.com/DIYgod/RSSHub for self-hosting instructions.
AIRADAR_RSSHUB_URL=https://rsshub.app

# --- Platform selection ---
# local (default) or cloudflare
AIRADAR_PLATFORM=local

# --- Cloudflare D1 (only needed when PLATFORM=cloudflare) ---
# Get these from: https://dash.cloudflare.com
AIRADAR_CF_ACCOUNT_ID=
AIRADAR_CF_D1_DATABASE_ID=
AIRADAR_CF_API_TOKEN=

# --- Runner / execution ---
# How collectors + maintenance run:
#   process → long-lived APScheduler loop (VDS / Docker)
#   batch   → single one-shot pass, no scheduler (serverless / CI cron)
#   auto    → pick by AIRADAR_PLATFORM (local→process, cloudflare→batch)
AIRADAR_RUNNER=auto
AIRADAR_ENABLE_DISCOVERY=true
# Ignored on non-VDS runners (the batch runner never starts stream collectors).
AIRADAR_ENABLE_STREAMING=true
# Max domain candidates probed per discovery run.
AIRADAR_DISCOVERY_LIMIT=40
# Per-probe HTTP timeout in seconds.
AIRADAR_PROBE_TIMEOUT=15.0
# 0 = unlimited (VDS); >0 caps total outbound subrequests (serverless budgets).
AIRADAR_MAX_SUBREQUESTS=0
